    channel_dist = df['Channel'].value_counts().sort_index()
    for channel, count in channel_dist.items():
        print(f"   - Canal {int(channel)}: {count} redes")
    
    print("\n3. ANÁLISIS DE INTERFERENCIAS POR CANAL:")
    
